  staffs              Staff[]
  @@map("companies")
}

model Store {
  id          String    @id @default(cuid())
  company_id  String
  company     Company   @relation(fields: [company_id], references: [id])
  name        String
  store_code  String    @unique // e.g. "SHB" → property_number prefix
  postal_code String?
  address     String?
  phone       String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  staff       Staff[]
  properties  Property[]
  @@map("stores")
}

model Staff {
  id                String    @id @default(cuid())
  company_id        String?
  company           Company?  @relation(fields: [company_id], references: [id])
  store_id          String?
  store             Store?    @relation(fields: [store_id], references: [id])

  // ===== 権限 =====
  permission        String    @default("AGENT")

  // ===== 基本情報 =====
  employee_number   String?   @unique
  name              String
  name_kana         String?
  name_en           String?
  nickname          String?

  // ===== 役職・資格 =====
  position          String?
  qualifications    String[]
  takken_number     String?
  takken_prefecture String?
  takken_expires_at DateTime?

  // ===== 業務用連絡先 =====
  email_work        String?   @unique
  tel_work          String?
  tel_mobile        String?
  extension         String?

  // ===== 個人情報 =====
  email_personal    String?
  tel_personal      String?
  postal_code       String?
  prefecture        String?
  city              String?
  address           String?
  birth_date        DateTime?
  gender            String?
  blood_type        String?
  emergency_contact String?
  emergency_tel     String?
  emergency_relation String?

  // ===== 雇用情報 =====
  employment_type   String?
  hire_date         DateTime?
  trial_end_date    DateTime?
  department        String?
  annual_salary     Int?

  // ===== 不動産業務スキル =====
  specialty_areas   String[]
  specialty_types   String[]
  monthly_target    Int?
  career_history    String?

  // ===== HP・プロフィール公開情報 =====
  photo_url         String?
  bio               String?
  catchphrase       String?
  qualification     String?
  favorite_word     String?
  hobby             String?
  memorable_client  String?
  sub_image_url_1   String?
  sub_image_url_2   String?
  daily_mindset     String?
  published_hp      Boolean   @default(false)
  hp_order          Int       @default(0)

  // ===== 採用ページ =====
  show_on_recruit   Boolean   @default(false)
  joined_at         String?
  motto             String?
  favorite          String?
  interview_q1      String?
  interview_q2      String?
  interview_q3      String?
  interview_q4      String?
  interview_q5      String?
  interview_q6      String?

  // ===== 在籍・退職 =====
  is_active         Boolean   @default(true)
  retirement_date   DateTime?
  retirement_reason String?
  successor_id      String?

  // ===== 物件番号コード =====
  staff_code          String?   @unique  // 物件番号用コード（例: r.kato）

  // ===== 認証情報 =====
  password_hash       String?
  login_count         Int       @default(0)
  is_locked           Boolean   @default(false)
  failed_login_count  Int       @default(0)

  // ===== システム =====
  last_login_at     DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  // ===== リレーション =====
  properties_as_agent     Property[] @relation("PropertyAgent")
  properties_as_successor Property[] @relation("PropertySuccessor")
  transfers_from PropertyTransfer[] @relation("TransferFrom")
  transfers_to   PropertyTransfer[] @relation("TransferTo")
  inquiries_assigned  Inquiry[] @relation("InquiryAgent")
  customers_assigned  Customer[] @relation("CustomerAgent")
  private_properties_as_agent PrivateProperty[] @relation("PrivatePropertyAgent")
  contracts_as_takken  Contract[] @relation("ContractTakken")
  testimonials         Testimonial[]
  sale_results         SaleResult[]
  check_logs           PropertyCheckLog[]

  @@map("staffs")
}

// ===== 未公開物件DB =====
