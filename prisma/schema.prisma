generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id                    String    @id @default(cuid())
  legacy_id             String?   @unique

  // 物件種別・取引態様
  property_type         String    // NEW_HOUSE, USED_HOUSE, MANSION, NEW_MANSION, LAND
  transaction_type      String    @default("仲介")
  brokerage_type        String    @default("専任")

  // ステータス
  status                String    @default("DRAFT")

  // キャッチコピー・説明
  title                 String?
  catch_copy            String?
  description_hp        String?
  description_portal    String?
  description_suumo     String?
  description_athome    String?

  // 所在地
  prefecture            String    @default("東京都")
  city                  String    @default("")
  address               String    @default("")
  address_chiban        String?
  postal_code           String?
  // 住所表示設定
  address_display_level   String    @default("town") // town | city | custom
  address_display_custom  String?
  town                    String?   // 町名丁目（表示用）
  building_name           String?
  room_number             String?
  latitude                Float?
  longitude               Float?

  // 価格
  price                 Int       @default(0)
  price_land            Int?
  price_build           Int?
  price_tax_inc         Boolean   @default(false)
  price_per_m2          Float?
  price_negotiable        Boolean   @default(false)
  ad_transfer_consent     String    @default("あり")

  // 交通（3駅まで）
  station_line1         String?
  station_name1         String?
  station_walk1         Int?
  station_line2         String?
  station_name2         String?
  station_walk2         Int?
  station_line3         String?
  station_name3         String?
  station_walk3         Int?
  bus_stop1               String?
  bus_time1               Int?
  bus_stop2               String?
  bus_time2               Int?
  bus_stop3               String?
  bus_time3               Int?

  // 面積
  area_land_m2          Float?
  area_land_tsubo       Float?
  area_build_m2         Float?
  area_build_tsubo      Float?
  area_exclusive_m2     Float?
  area_exclusive_tsubo  Float?
  area_balcony_m2       Float?

  // 建物情報
  rooms                 String?
  building_year         Int?
  building_month        Int?
  structure             String?
  floors_total          Int?
  floors_basement       Int?
  floor_unit            Int?
  direction             String?
  total_units           Int?
  rooms_count             Int?
  ldk_size                Float?

  // 法令・権利
  city_plan             String?
  use_zone              String?
  use_zones             Json?     // [{zone, bcr, far, area_pct}] 複数用途地域
  bcr                   Float?
  far                   Float?
  land_right            String?
  land_category         String?
  road_side             String?
  road_width            Float?
  road_type             String?
  private_road          Boolean   @default(false)
  setback_required      Boolean   @default(false)
  setback_area          Float?
  road_direction          String?
  road_contact            String?
  roads                   Json?     // [{direction, width, type, contact}] 複数接道
  building_conditions     Boolean   @default(false)
  rebuild_allowed         String?
  national_land_act       Boolean   @default(false)
  agricultural_act        Boolean   @default(false)
  landscape_act           Boolean   @default(false)

  // 費用・管理
  management_fee        Int?
  repair_reserve        Int?
  other_monthly_fee     Int?
  land_lease_fee        Int?
  fixed_asset_tax       Int?
  city_planning_tax     Int?
  management_type       String?
  management_company    String?

  // 引渡し・レインズ
  delivery_timing       String?
  delivery_status       String?
  reins_number          String?
  reins_registered_at   DateTime?
  ad_valid_until        DateTime?
  reins_updated_at        DateTime?
  reins_status            String?
  delivery_condition      String?

  // 売主情報（内部管理・非公開）
  seller_company          String?
  seller_phone            String?
  seller_contact          String?
  seller_fax              String?
  seller_agent            String?
  seller_transaction_type String?
  seller_brokerage_type   String?
  purchase_price          Int?
  purchase_date           DateTime?

  // 設備
  eq_autolock           Boolean   @default(false)
  eq_elevator           Boolean   @default(false)
  eq_parking            Boolean   @default(false)
  eq_parking_fee        Int?
  eq_bike_parking       Boolean   @default(false)
  eq_storage            Boolean   @default(false)
  eq_pet_ok             Boolean   @default(false)
  eq_system_kitchen     Boolean   @default(false)
  eq_all_electric       Boolean   @default(false)
  eq_floor_heating      Boolean   @default(false)
  eq_ac                 Boolean   @default(false)
  eq_solar              Boolean   @default(false)
  eq_home_security      Boolean   @default(false)
  eq_walk_in_closet     Boolean   @default(false)
  eq_2f_washroom        Boolean   @default(false)
  eq_washlet            Boolean   @default(false)
  eq_bathroom_dryer     Boolean   @default(false)
  eq_tv_intercom        Boolean   @default(false)
  eq_fiber_optic        Boolean   @default(false)
  eq_bs_cs              Boolean   @default(false)
  eq_gas_city           Boolean   @default(false)
  eq_gas_prop           Boolean   @default(false)
  eq_water_city         Boolean   @default(false)
  eq_water_well         Boolean   @default(false)
  eq_sewage             Boolean   @default(false)
  eq_septic             Boolean   @default(false)
  eq_corner             Boolean   @default(false)
  eq_top_floor          Boolean   @default(false)
  eq_new_interior       Boolean   @default(false)
  eq_new_exterior       Boolean   @default(false)
  eq_reform_kitchen     Boolean   @default(false)
  eq_reform_bath        Boolean   @default(false)

  // ===== 設備拡充（2024-2025年トレンド）=====
  // キッチン詳細
  eq_counter_kitchen      Boolean @default(false)
  eq_cupboard             Boolean @default(false)
  eq_pantry               Boolean @default(false)
  eq_touchless_faucet     Boolean @default(false)
  // 浴室・洗面・トイレ
  eq_unit_bath            Boolean @default(false)
  eq_separate_bath_toilet Boolean @default(false)
  eq_double_wash          Boolean @default(false)
  eq_laundry_space        Boolean @default(false)
  eq_laundry_outdoor      Boolean @default(false)
  eq_toilet_count         Int?
  eq_washlet_all          Boolean @default(false)
  // 収納
  eq_shoe_closet          Boolean @default(false)
  eq_trunk_room           Boolean @default(false)
  eq_roof_storage         Boolean @default(false)
  eq_all_room_storage     Boolean @default(false)
  // 省エネ・環境
  eq_high_insulation      Boolean @default(false)
  eq_long_quality         Boolean @default(false)
  eq_zeh                  Boolean @default(false)
  eq_storage_battery      Boolean @default(false)
  eq_ev_charger           Boolean @default(false)
  eq_double_glazing       Boolean @default(false)
  eq_ventilation          Boolean @default(false)
  // セキュリティ詳細
  eq_crime_prevention_glass Boolean @default(false)
  eq_electronic_lock      Boolean @default(false)
  eq_security_light       Boolean @default(false)
  // 駐車・駐輪詳細
  eq_parking_roofed       Boolean @default(false)
  eq_parking_2cars        Boolean @default(false)
  eq_electric_shutter     Boolean @default(false)
  eq_bicycle_count        Int?
  // 快適性
  eq_floor_heating_all    Boolean @default(false)
  eq_ceiling_height       Float?
  eq_barrier_free         Boolean @default(false)
  eq_elevator_private     Boolean @default(false)
  // 通信・AV
  eq_optical_fiber        Boolean @default(false)
  eq_cable_tv             Boolean @default(false)
  eq_interphone_video     Boolean @default(false)
  // 外構・庭
  eq_terrace              Boolean @default(false)
  eq_roof_balcony         Boolean @default(false)
  eq_patio                Boolean @default(false)
  eq_wood_deck            Boolean @default(false)
  // リフォーム・リノベ
  eq_reformed             Boolean @default(false)
  eq_renovated            Boolean @default(false)
  eq_reform_year          Int?
  eq_new_kitchen          Boolean @default(false)
  eq_new_bath             Boolean @default(false)
  eq_new_toilet           Boolean @default(false)
  eq_new_floor            Boolean @default(false)
  eq_new_wall             Boolean @default(false)
  // 耐震
  eq_earthquake_resistant String?
  eq_seismic_isolation    Boolean @default(false)
  eq_vibration_control    Boolean @default(false)
  // 周辺環境
  env_elementary_school   String?
  env_junior_high_school  String?
  school_elementary       String?  // 小学校区（自動取得）
  school_junior_high      String?  // 中学校区（自動取得）
  env_supermarket         String?
  env_hospital            String?
  env_park                String?
  env_disaster_risk       String?
  env_crime_level         String?
  env_noise_level         String?
  env_sunlight            String?
  env_view                String?

  // 設備・仕様（ポータル対応チェックボックス）
  features              String[]  @default([])

  // 掲載設定
  published_hp          Boolean   @default(false)
  published_members     Boolean   @default(false)
  published_suumo       Boolean   @default(false)
  published_athome      Boolean   @default(false)
  published_yahoo       Boolean   @default(false)
  published_homes       Boolean   @default(false)
  published_at          DateTime?

  // ポータルID
  suumo_id              String?
  athome_id             String?
  yahoo_id              String?
  homes_id              String?

  // コンプライアンス
  compliance_checked    Boolean   @default(false)
  compliance_checked_at DateTime?
  compliance_result     Json?

  // ワークフロー・広告確認
  ad_confirmation_sent_at DateTime?
  ad_confirmation_method  String?   // FAX | EMAIL | VISIT
  ad_confirmed_at         DateTime?
  ad_confirmed_by         String?
  ad_confirmation_file    String?
  last_ad_check_date      DateTime?

  // 写真集計キャッシュ
  photo_count             Int       @default(0)
  photo_has_exterior      Boolean   @default(false)
  photo_has_floor_plan    Boolean   @default(false)
  photo_has_interior      Boolean   @default(false)
  photo_last_updated_at   DateTime?

  // 掲載管理
  last_confirmed_at       DateTime?
  days_on_market          Int?
  inquiry_count           Int       @default(0)

  // タスク管理
  pending_tasks           String[]

  // 広告文
  selling_points          String[]

  // AIチェック結果
  last_confirmed_by       String?
  last_check_result       Json?

  // 内部情報
  property_number       String?
  agent_id              String?
  successor_agent_id    String?
  store_id              String?
  internal_memo         String?
  source                String?

  // 広告承諾（売主からの広告承諾取得記録）
  ad_approval_contact   String?   // 承諾取得先担当者名
  ad_approval_method    String?   // EMAIL | PHONE | SELF
  ad_approval_date      DateTime? // 承諾取得日

  // HP表示フラグ
  is_felia_selection    Boolean   @default(false)  // 厳選物件フラグ
  is_open_house         Boolean   @default(false)  // 現地販売会フラグ
  open_house_start      DateTime?                  // 現地販売会開始日
  open_house_end        DateTime?                  // 現地販売会終了日

  is_deleted            Boolean   @default(false)
  deleted_at            DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  // 物件確認管理
  last_checked_at       DateTime?
  check_interval_days   Int       @default(14)

  history               PropertyHistory[]
  images                PropertyImage[]
  store                 Store?    @relation(fields: [store_id], references: [id])
  agent                 Staff?    @relation("PropertyAgent", fields: [agent_id], references: [id])
  successor_agent       Staff?    @relation("PropertySuccessor", fields: [successor_agent_id], references: [id])
  inquiries             Inquiry[]
  contracts             Contract[]
  sale_results          SaleResult[] @relation("SaleResultProperty")
  check_logs            PropertyCheckLog[]
  env_image_links       PropertyEnvImageLink[]
  documents             PropertyDocument[]
  @@map("properties")
}

model PropertyDocument {
  id          String   @id @default(cuid())
  property_id String
  name        String
  url         String
  file_type   String   @default("pdf")
  memo        String?
  uploaded_at DateTime @default(now())
  sort_order  Int      @default(0)

  property    Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@map("property_documents")
}

model PropertyCheckLog {
  id          String    @id @default(cuid())
  property_id String
  property    Property  @relation(fields: [property_id], references: [id], onDelete: Cascade)
  checked_by  String?
  staff       Staff?    @relation(fields: [checked_by], references: [id], onDelete: SetNull)
  checked_at  DateTime  @default(now())
  old_price   Decimal?  @db.Decimal(12, 2)
  new_price   Decimal?  @db.Decimal(12, 2)
  note        String?
  created_at  DateTime  @default(now())
  @@map("property_check_logs")
}

model PropertyImage {
  id              String   @id @default(cuid())
  property_id     String
  property        Property @relation(fields: [property_id], references: [id])
  url             String
  filename        String
  file_size       Int?
  mime_type       String?
  order           Int      @default(0)
  room_type       String?  // LIVING, KITCHEN, BEDROOM, BATHROOM, ENTRANCE, EXTERIOR, FLOOR_PLAN, BALCONY, OTHER
  caption         String?
  ai_caption      String?
  ai_pr_text      String?
  ai_confidence   Float?
  ai_analyzed_at  DateTime?
  is_main         Boolean  @default(false)
  uploaded_by     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  @@map("property_images")
}

model MansionBuilding {
  id                 String   @id @default(cuid())
  name               String
  name_kana          String?
  prefecture         String?
  city               String?
  address            String?
  total_units        Int?
  built_year         Int?
  built_month        Int?
  structure          String?
  floors_total       Int?
  floors_basement    Int?
  management_company String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  exterior_images    MansionExteriorImage[]
  @@map("mansion_buildings")
}

model MansionExteriorImage {
  id         String          @id @default(cuid())
  mansion_id String
  mansion    MansionBuilding @relation(fields: [mansion_id], references: [id])
  url        String
  filename   String
  caption    String?
  is_primary Boolean  @default(false)
  created_at DateTime @default(now())
  @@map("mansion_exterior_images")
}

model PropertyEnvironmentImage {
  id            String   @id @default(cuid())
  url           String
  filename      String
  facility_type String   // SCHOOL, SUPERMARKET, PARK, STATION, HOSPITAL, CONVENIENCE_STORE, OTHER
  facility_name String?
  prefecture    String?
  city          String?
  address       String?
  latitude      Float?
  longitude     Float?
  caption       String?
  ai_caption    String?
  uploaded_by   String?
  created_at    DateTime @default(now())
  property_links PropertyEnvImageLink[]
  @@map("property_environment_images")
}

model PropertyEnvImageLink {
  id           String                   @id @default(cuid())
  property_id  String
  env_image_id String
  property     Property                 @relation(fields: [property_id], references: [id], onDelete: Cascade)
  env_image    PropertyEnvironmentImage @relation(fields: [env_image_id], references: [id], onDelete: Cascade)
  created_at   DateTime                 @default(now())
  @@unique([property_id, env_image_id])
  @@map("property_env_image_links")
}

model PropertyHistory {
  id             String   @id @default(cuid())
  property_id    String
  property       Property @relation(fields: [property_id], references: [id])
  changed_by     String
  change_type    String
  changed_fields Json
  note           String?
  created_at     DateTime @default(now())
  @@map("property_history")
}

model AdApproval {
  id               String    @id @default(cuid())
  property_id      String
  status           String
  approved_by      String?
  approved_at      DateTime?
  publish_settings Json?
  notes            String?
  created_at       DateTime  @default(now())
  @@map("ad_approvals")
}

model SaleRecord {
  id                String   @id @default(cuid())
  property_id       String   @unique
  sold_price        Int
  listed_price      Int
  price_diff_pct    Float
  days_on_market    Int
  inquiry_count     Int      @default(0)
  viewing_count     Int      @default(0)
  buyer_type        String?
  price_per_m2      Float?
  sold_at           DateTime
  agent_id          String?
  season            String?
  property_snapshot Json
  created_at        DateTime @default(now())
  @@map("sale_records")
}

model CompetitorListing {
  id               String    @id @default(cuid())
  source           String
  source_id        String
  property_type    String?
  address_city     String?
  station_name     String?
  station_walk     Int?
  price            Int?
  area_m2          Float?
  rooms            String?
  first_seen_at    DateTime  @default(now())
  last_seen_at     DateTime  @default(now())
  sold_detected_at DateTime?
  price_history    Json?
  @@unique([source, source_id])
  @@map("competitor_listings")
}

model Viewing {
  id              String   @id @default(cuid())
  property_id     String
  customer_crm_id String
  agent_id        String?
  scheduled_at    DateTime
  status          String   @default("scheduled")
  notes           String?
  feedback        String?
  google_event_id String?
  created_at      DateTime @default(now())
  @@map("viewings")
}

model DocumentParseLog {
  id           String    @id @default(cuid())
  property_id  String?
  source_type  String
  source_url   String
  parse_result Json
  confidence   Json
  confirmed_by String?
  confirmed_at DateTime?
  created_at   DateTime  @default(now())
  @@map("document_parse_logs")
}

model AuditLog {
  id          String   @id @default(cuid())
  entity_type String
  entity_id   String
  action      String
  actor_id    String
  before      Json?
  after       Json?
  note        String?
  created_at  DateTime @default(now())
  @@map("audit_logs")
}

// ===== 反響（ポータルサイトからの問い合わせ） =====
model Inquiry {
  id                String    @id @default(cuid())

  // 反響元
  source            String    // SUUMO | ATHOME | YAHOO | HOMES | HP | TEL | WALK_IN | OTHER
  source_email_id   String?   @unique // GmailのメッセージID（重複取込防止）
  received_at       DateTime  // 反響受信日時
  raw_email         String?   // 生メール本文（解析用）

  // 問い合わせ物件
  property_id       String?
  property_number   String?   // 物件番号（DB未登録でも保持）
  property_name     String?   // 物件名（メールから抽出）

  // 問い合わせ内容
  inquiry_type      String    @default("PROPERTY") // PROPERTY | ASSESSMENT | GENERAL
  message           String?
  visit_hope        Boolean   @default(false)
  document_hope     Boolean   @default(false)

  // 顧客情報（メールから自動抽出）
  customer_id       String?
  customer_name     String?
  customer_email    String?
  customer_tel      String?
  customer_address  String?
  customer_note     String?

  // 担当者振り分け
  assigned_to       String?
  assigned_at       DateTime?
  assigned_by       String?
  assignment_reason String?

  // 対応状況
  status            String    @default("NEW") // NEW | CONTACTED | VISITING | NEGOTIATING | CLOSED | LOST
  first_contact_at  DateTime?
  response_time_min Int?
  priority          String    @default("NORMAL") // HIGH | NORMAL | LOW
  ai_score          Int?
  ai_notes          String?

  // メモ
  internal_memo     String?
  token             String?   // プライベートセレクション経由の場合のトークン
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  // リレーション
  customer          Customer? @relation(fields: [customer_id], references: [id])
  property          Property? @relation(fields: [property_id], references: [id])
  assigned_staff    Staff?    @relation("InquiryAgent", fields: [assigned_to], references: [id])
  activities        InquiryActivity[]

  @@map("inquiries")
}

// ===== 対応履歴 =====
model InquiryActivity {
  id          String   @id @default(cuid())
  inquiry_id  String
  inquiry     Inquiry  @relation(fields: [inquiry_id], references: [id])
  staff_id    String?
  type        String   // EMAIL | CALL | VISIT | NOTE | STATUS_CHANGE
  content     String
  created_at  DateTime @default(now())

  @@map("inquiry_activities")
}

model Customer {
  id                     String    @id @default(cuid())
  legacy_id              String?   @unique

  // ===== 基本情報 =====
  name                   String
  name_kana              String?
  email                  String?   @unique
  tel                    String?
  tel_mobile             String?
  line_id                String?

  // ===== 現住所 =====
  postal_code            String?
  prefecture             String?
  city                   String?
  address                String?
  current_housing_type   String?   // 賃貸 | 持家 | 社宅 | 実家 | その他
  current_rent           Int?
  current_housing_note   String?

  // ===== 購入希望条件 =====
  desired_property_type  String[]
  desired_areas          String[]
  desired_stations       String[]
  desired_budget_min     Int?
  desired_budget_max     Int?
  desired_area_min       Float?
  desired_area_max       Float?
  desired_rooms          String[]
  desired_floor_min      Int?
  desired_building_year  Int?
  desired_walk_max       Int?
  desired_move_timing    String?
  desired_features       String[]
  desired_note           String?

  // ===== 資金計画 =====
  finance_type           String?   // 現金 | ローン | 併用
  down_payment           Int?
  annual_income          Int?
  loan_preapproval       String?   // 未実施 | 審査中 | 承認済 | 否決
  loan_amount            Int?
  loan_bank              String?
  has_property_to_sell   Boolean   @default(false)
  sell_property_note     String?

  // ===== 反響・流入情報 =====
  source                 String?
  source_detail          String?
  first_inquiry_at       DateTime?
  first_inquiry_property String?

  // ===== 対応状況 =====
  status                 String    @default("NEW")
  // NEW | CONTACTING | VISITING | NEGOTIATING | CONTRACT | CLOSED | LOST | PENDING
  priority               String    @default("NORMAL")
  ai_score               Int?
  ai_analysis            String?
  ai_next_action         String?
  ai_analyzed_at         DateTime?

  // ===== 担当者 =====
  assigned_to            String?
  assigned_at            DateTime?
  store_id               String?

  // ===== 追客管理 =====
  last_contact_at        DateTime?
  next_contact_at        DateTime?
  next_contact_note      String?
  contact_frequency      String?
  do_not_contact         Boolean   @default(false)
  unsubscribed           Boolean   @default(false)

  // ===== 内部メモ =====
  internal_memo          String?
  tags                   String[]

  // ===== HP会員 =====
  is_member              Boolean   @default(false)
  member_registered_at   DateTime?
  member_id              String?   @unique
  member                 Member?   @relation(fields: [member_id], references: [id])

  // ===== システム =====
  is_deleted             Boolean   @default(false)
  deleted_at             DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  // リレーション
  family_members         FamilyMember[]
  inquiries              Inquiry[]
  activities             CustomerActivity[]
  contracts              Contract[]
  assigned_staff         Staff?    @relation("CustomerAgent", fields: [assigned_to], references: [id])
