}

model CustomerActivity {
  id             String    @id @default(cuid())
  customer_id    String
  customer       Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  staff_id       String?
  type           String    // CALL | EMAIL | LINE | VISIT | MEETING | VIEWING | NOTE | AI_AUTO
  direction      String    @default("OUTBOUND") // INBOUND | OUTBOUND
  content        String
  property_id    String?
  result         String?
  next_action    String?
  next_action_at DateTime?
  created_at     DateTime  @default(now())
  @@map("customer_activities")
}

model Company {
  id                  String    @id @default(cuid())
  name                String
  name_kana           String?
  license_number      String?   // 宅建業免許番号 e.g. "東京都知事(3)第12345号"
  license_expiry      DateTime? // 免許有効期限
  postal_code         String?
  address             String?
  phone               String?
  fax                 String?
  representative      String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
