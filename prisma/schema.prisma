generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id                  String    @id @default(cuid())
  legacy_id           String?   @unique
  property_type       String
  status              String    @default("DRAFT")
  title               String?
  catch_copy          String?
  prefecture          String    @default("東京都")
  city                String
  address             String    @default("")
  price               Int
  area_land_m2        Float?
  area_build_m2       Float?
  area_exclusive_m2   Float?
  station_line        String?
  station_name        String
  station_walk        Int
  building_year       Int?
  building_month      Int?
  structure           String?
  rooms               String?
  floors_total        Int?
  floor_unit          Int?
  delivery_timing     String?
  reins_number        String?
  city_plan           String?
  use_zone            String?
  bcr                 Float?
  far                 Float?
  private_road        Boolean   @default(false)
  management_fee      Int?
  repair_reserve      Int?
  total_units         Int?
  description_hp      String?
  description_portal  String?
  published_hp        Boolean   @default(false)
  published_suumo     Boolean   @default(false)
  published_athome    Boolean   @default(false)
  published_at        DateTime?
  compliance_checked  Boolean   @default(false)
  compliance_checked_at DateTime?
  compliance_result   Json?
  agent_id            String?
  is_deleted          Boolean   @default(false)
  deleted_at          DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  history             PropertyHistory[]
  @@map("properties")
}

model PropertyHistory {
  id             String   @id @default(cuid())
  property_id    String
  property       Property @relation(fields: [property_id], references: [id])
  changed_by     String
  change_type    String
  changed_fields Json
  note           String?
  created_at     DateTime @default(now())
  @@map("property_history")
}

model AdApproval {
  id               String    @id @default(cuid())
  property_id      String
  status           String
  approved_by      String?
  approved_at      DateTime?
  publish_settings Json?
  notes            String?
  created_at       DateTime  @default(now())
  @@map("ad_approvals")
}

model SaleRecord {
  id                String   @id @default(cuid())
  property_id       String   @unique
  sold_price        Int
  listed_price      Int
  price_diff_pct    Float
  days_on_market    Int
  inquiry_count     Int      @default(0)
  viewing_count     Int      @default(0)
  buyer_type        String?
  price_per_m2      Float?
  sold_at           DateTime
  agent_id          String?
  season            String?
  property_snapshot Json
  created_at        DateTime @default(now())
  @@map("sale_records")
}

model CompetitorListing {
  id               String    @id @default(cuid())
  source           String
  source_id        String
  property_type    String?
  address_city     String?
  station_name     String?
  station_walk     Int?
  price            Int?
  area_m2          Float?
  rooms            String?
  first_seen_at    DateTime  @default(now())
  last_seen_at     DateTime  @default(now())
  sold_detected_at DateTime?
  price_history    Json?
  @@unique([source, source_id])
  @@map("competitor_listings")
}

model Viewing {
  id              String   @id @default(cuid())
  property_id     String
  customer_crm_id String
  agent_id        String?
  scheduled_at    DateTime
  status          String   @default("scheduled")
  notes           String?
  feedback        String?
  google_event_id String?
  created_at      DateTime @default(now())
  @@map("viewings")
}

model DocumentParseLog {
  id           String    @id @default(cuid())
  property_id  String?
  source_type  String
  source_url   String
  parse_result Json
  confidence   Json
  confirmed_by String?
  confirmed_at DateTime?
  created_at   DateTime  @default(now())
  @@map("document_parse_logs")
}

model AuditLog {
  id          String   @id @default(cuid())
  entity_type String
  entity_id   String
  action      String
  actor_id    String
  before      Json?
  after       Json?
  note        String?
  created_at  DateTime @default(now())
  @@map("audit_logs")
}

model Customer {
  id                 String    @id @default(cuid())
  crm_id             String?   @unique
  name               String
  name_kana          String?
  email              String?
  phone              String?
  budget_min         Int?
  budget_max         Int?
  area_preferences   Json?
  property_type_pref String?
  rooms_pref         String?
  area_m2_pref       Float?
  status             String    @default("lead")
  notes              String?
  source             String?
  assigned_agent_id  String?
  last_contacted_at  DateTime?
  next_action_date   DateTime?
  next_action_note   String?
  is_deleted         Boolean   @default(false)
  deleted_at         DateTime?
  contracts          Contract[]
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  @@map("customers")
}

model Contract {
  id                String    @id @default(cuid())
  property_id       String
  customer_id       String?
  customer          Customer? @relation(fields: [customer_id], references: [id])
  agent_id          String?
  status            String    @default("draft")
  contract_price    Int
  commission_type   String    @default("both")
  commission_amount Int?
  commission_rate   Float?
  contract_date     DateTime?
  settlement_date   DateTime?
  notes             String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  @@map("contracts")
}