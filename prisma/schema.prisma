  @@map("customers")
}

model FamilyMember {
  id            String   @id @default(cuid())
  customer_id   String
  customer      Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  relation      String   // 本人 | 配偶者 | 子供 | 親 | その他
  name          String?
  name_kana     String?
  age           Int?
  birth_year    Int?
  occupation    String?  // 会社員 | 自営業 | 公務員 | 専業主婦 | 学生 | 無職
  annual_income Int?
