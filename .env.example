# =============================================================
# フェリアホーム 物件情報管理システム — 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
#
# ⚠️ 既存プロジェクトの .env とは完全に別ファイルです
# ⚠️ .env.local は .gitignore に含まれており git 管理外です
# =============================================================

# アプリURL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===== データベース（このシステム専用 — 既存DBとは別） =====
# 既存プロジェクトのDBには接続しません
# ローカル開発: ポート 5433 を使用（既存の 5432 と衝突しないよう）
DATABASE_URL="postgresql://felia_property:password@localhost:5433/felia_property?schema=public"

# ===== Claude AI =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 認証（管理画面は社内限定） =====
NEXTAUTH_URL=http://localhost:3001
# 以下コマンドで生成: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# ===== AWS S3（物件写真・PDF） =====
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=felia-property-assets

# ===== Slack通知 =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL_PROPERTY=#property-updates
SLACK_CHANNEL_ALERTS=#property-alerts

# ===== 既存CRM連携（APIのみ — DBには直接接続しない） =====
CRM_API_BASE_URL=https://crm.felia-home.co.jp/api
CRM_API_KEY=

# ===== 外部ポータルAPI（取得次第追加） =====
SUUMO_API_KEY=
ATHOME_API_KEY=
YAHOO_REAL_ESTATE_API_KEY=
HOMES_API_KEY=

# ===== Google Calendar（内見管理） =====
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ===== 査定用公的データ =====
# 国土交通省 不動産情報ライブラリ
MLIT_API_KEY=

# ===== 管理画面URL（Slack通知のリンク生成用） =====
ADMIN_BASE_URL=http://localhost:3001/admin

# Gmail API（反響メール自動取込）
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=
INQUIRY_CHECK_INTERVAL=300

# ===== 開発設定 =====
PORT=3001
NODE_ENV=development
